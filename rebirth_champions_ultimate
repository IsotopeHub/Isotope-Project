local miscTab = window:CreateTab("Misc Tab", "circle-ellipsis")
local miscSection = miscTab:CreateSection("Misc")

local collectMiniChests = miscTab:CreateButton({
	Name = "Collect Mini Chest",
	Callback = function()
		if _G.playerIsBusy then NotifyPlayerBusy() return end
		_G.playerIsBusy = true
		
		local unclockedMaps = dataController.data.maps
		
		for _, mapId in unclockedMaps do
			local map = maps:FindFirstChild(mapsList[mapId].name)
			if not map then continue end
			
			local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
			local humanoid = character:WaitForChild("Humanoid")
			local rootPart = character:WaitForChild("HumanoidRootPart")

			local miniChests = map:FindFirstChild("MiniChests")
			if not miniChests then continue end

			for _, chest in miniChests:GetChildren() do
				local touchPart = chest:FindFirstChild("Touch")
				if not touchPart then continue end

				local prompt = touchPart:FindFirstChildOfClass("ProximityPrompt")
				if not prompt then continue end

				prompt.HoldDuration = 0

				local distance = (rootPart.Position - touchPart.Position).Magnitude
				local speed = 100
				local info = TweenInfo.new(distance / speed, Enum.EasingStyle.Linear)

				local tween = TweenService:Create(rootPart, info, {CFrame = touchPart.CFrame})

				tween:Play()
				tween.Completed:Wait()

				task.wait(0.1)
				
				for i = 1, 5, 1 do
					prompt:InputHoldBegin()
					task.wait(0.1)
					prompt:InputHoldEnd()
				end
				
				task.wait(5)
			end
		end

		_G.playerIsBusy = false
	end,
})
