-- update rebirth dropdown
task.spawn(function()
	dataController:waitForData()

	while true do
		local data = dataController.data
		
		if data then
			local currentUpgradeLevel = data.upgrades.rebirthButtons or 0
			local upgradeData = upgradeList.rebirthButtons.upgrades[currentUpgradeLevel]

			local newList = {}
			local newMapping = {}
			local newLabelForCurrentIndex = nil

			for index, multiplier in rebirthList do
				if upgradeData.value >= index then
					local currentTotalRebirths = data.rebirths
					local price = (variables.rebirthPrice + currentTotalRebirths * variables.rebirthPriceMultiplier) * multiplier + variables.rebirthPriceMultiplier * (multiplier * (multiplier - 1) / 2)

					local formattedAmount = sharedFunctions.suffixes(multiplier, 2, true)
					local formattedPrice = sharedFunctions.suffixes(price)

					local label = formattedAmount .. " Rebirths (" .. formattedPrice .. ")"

					table.insert(newList, label)
					newMapping[label] = index

					if selectedRebirthIndex == index then
						newLabelForCurrentIndex = label
					end
				end
			end

			rebirthMapping = newMapping

			if selectRebirthDropdown then
				selectRebirthDropdown:Refresh(newList, false)

				if newLabelForCurrentIndex then
					selectRebirthDropdown:Set(newLabelForCurrentIndex)
				end
			end
		end

		task.wait(1)
	end
end)

