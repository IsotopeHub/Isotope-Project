-- update avaible trees
task.spawn(function()
	dataController:waitForData()

	while true do
		local data = dataController:getData()

		if data and data.maps then
			local newList = {}

			table.insert(newList, "SPAWN")
			table.insert(newList, "FALL")

			for _, mapId in data.maps do
				for zoneKey, zoneData in treeList do
					local zoneNameUpper = zoneKey:upper()
					if (tostring(zoneData.mapId) == tostring(mapId) or zoneKey == tostring(mapId)) then
						local exists = false
						
						for _, value in newList do
							if value == zoneNameUpper then exists = true break end
						end

						if not exists then
							table.insert(newList, zoneNameUpper)
						end
					end
				end
			end

			if selectTreeDropdown then
				local current = selectTreeDropdown.CurrentOption[1]
				selectTreeDropdown:Refresh(newList, false)

				if current and current ~= "" then
					pcall(function() selectTreeDropdown:Set(current) end)
				end
			end
		end

		task.wait(1)
	end
end)

local autoChopTreeToggle = farmTab:CreateToggle({
	Name = "Auto Chop Trees",
	CurrentValue = false,
	Flag = "AutoChopTreeToggle",
	Callback = function(Value)
		if not Value then _G.playerIsBusy = false return end
		_G.playerIsBusy = true

		task.spawn(function()
			while Rayfield.Flags["AutoChopTreeToggle"].CurrentValue do
				local selectedMap = Rayfield.Flags["SelectTreeDropdown"].CurrentOption[1]

				if not selectedMap or selectedMap == "" or selectedMap == "Loading..." then
					task.wait(1)
					continue
				end

				local data = dataController:getData()
				if not data.isAxeEquipped then
					for slot, itemData in data.inventory.exclusive do
						local itemObject = itemUtils.createItemFromData(itemData)
						if itemObject:getName():lower():find("axe") and not itemObject:getName():lower():find("pickaxe") then
							inventoryService:useItem(slot)
							task.wait(0.6)
							break 
						end
					end
				end

				local targetTree = nil
				for _, tree in CollectionService:GetTagged("Tree") do
					if tree:GetAttribute("groupId"):upper() == selectedMap:upper() then
						local treeId = tree:GetAttribute("treeId")
						local currentData = dataController:getData()

						if currentData.trees[tree:GetAttribute("groupId")] and currentData.trees[tree:GetAttribute("groupId")][treeId] then
							if currentData.trees[tree:GetAttribute("groupId")][treeId].hp > 0 then
								targetTree = tree
								break
							end
						end
					end
				end

				if targetTree then
					local model = targetTree:FindFirstChildWhichIsA("Model")
					local primary = model and model.PrimaryPart

					if primary then
						local character = localPlayer.Character
						local rootPart = character:WaitForChild("HumanoidRootPart")
						local distance = (rootPart.Position - primary.Position).Magnitude
						local speed = 100

						local tween = TweenService:Create(rootPart, TweenInfo.new(distance / speed, Enum.EasingStyle.Linear), { CFrame = primary.CFrame * CFrame.new(0, 0, 5) })
						tween:Play()
						tween.Completed:Wait()

						local groupId = targetTree:GetAttribute("groupId")
						local treeId = targetTree:GetAttribute("treeId")
						local lumberId = treeService:getLumberId()

						treeController:moveToTree(targetTree)
						treeController:autoDamageTree(targetTree)
						treeService.damage2:Fire(groupId, treeId, lumberId)

						repeat
							task.wait(0.5)
							local loopData = dataController:getData()
							local currentHp = (loopData.trees[groupId] and loopData.trees[groupId][treeId]) and loopData.trees[groupId][treeId].hp or 0
						until currentHp <= 0 or not Rayfield.Flags["AutoChopTreeToggle"].CurrentValue

						pcall(function() treeController:cancelAutoDamageTree() end)
					end
				end

				task.wait(0.5)
			end
		end)
	end,
})

