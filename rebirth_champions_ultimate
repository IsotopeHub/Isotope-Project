selecEggDropdown = eggTab:CreateDropdown({
	Name = "Select egg",
	Options = (function()
		local temporaryTable = {}

		for name, data in eggList do
			table.insert(temporaryTable, {
				name = name,
				cost = data.cost or 0
			})
		end

		table.sort(temporaryTable, function(a, b)
			return a.cost < b.cost
		end)

		local finalList = {}
		
		for _, item in temporaryTable do
			local label = item.name .. " (" .. sharedFunctions.suffixes(item.cost) .. ")"
			table.insert(finalList, label)
		end

		return finalList
	end)(),
	CurrentOption = {""},
	Flag = "SelecEggDropdown",
	Callback = function(Option)
		
	end,
})

